# Storage Flipper Agent Configuration

# eBay API (get from https://developer.ebay.com/)
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id

# Facebook Marketplace (currently uses manual posting)
# No API available for automated posting

# Google Sheets API (for inventory tracking)
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_INVENTORY_ID=your_sheet_id

# Pricing
DEFAULT_MARKUP=0.85  # Price at 85% of average for quick sale
QUICK_FLIP_THRESHOLD_DAYS=30

# Inventory
INVENTORY_LOCATION=warehouse  # or home, storage, etc.
